# --- Admin inicial (seed) ---
# O app agora e MULTIUSUARIO: cada pessoa tem login proprio (users.json, hashes
# scrypt). Estas duas variaveis criam o PRIMEIRO admin automaticamente quando
# users.json ainda nao existe; depois disso, gerencie a equipe pela UI (botao
# "Equipe", visivel so para admin). Mudar estes valores nao afeta usuarios ja
# criados. NUNCA preencha valores reais neste arquivo (.env.example vai para o
# repo publico): defina-os como variaveis de ambiente no host (ex.: Railway),
# ou copie para ".env" (ignorado pelo git).
APP_AUTH_USER=
APP_AUTH_PASSWORD=

# Diretorio de armazenamento persistente. Em producao aponte para um volume
# que sobreviva a restart/deploy (ex.: /data no Railway). Em branco = ./storage.
CONTAS_FLOW_STORAGE_DIR=

# --- Criptografia em repouso (RECOMENDADO em producao) ---
# Cifra os campos sensiveis no groups.json (senha, email de recuperacao,
# telefone, notas) e os refresh tokens do YouTube, com AES-256-GCM. Sem esta
# chave, esses dados ficam em TEXTO PLANO no arquivo (ok para uso local).
# Precisa ter 32 bytes, em hex (64 caracteres) ou base64. Gere uma com:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ATENCAO: guarde esta chave em local seguro e SEPARADO do volume de dados. Se
# voce perde-la, os campos cifrados ficam IRRECUPERAVEIS. Trocar a chave depois
# de ja ter dados cifrados exige re-migracao (nao implementada): defina-a UMA vez
# e mantenha.
CONTAS_FLOW_ENC_KEY=

# --- CORS (opcional) ---
# A API e a UI sao servidas da MESMA origem, entao normalmente nao precisa de
# nada aqui. So defina se for acessar a API de outra origem (ex.: front em outro
# dominio): coloque a origem exata permitida (https://app.exemplo.com). Em
# branco = somente same-origin (recomendado).
CONTAS_FLOW_ALLOWED_ORIGIN=

# --- Cookie de sessao (opcional) ---
# Por padrao o cookie e marcado "Secure" quando ha PORT definido (deploy atras
# de HTTPS) e sem "Secure" em http local. Force com 1 (sempre Secure) ou 0
# (nunca). So mexa se souber o que esta fazendo.
CONTAS_FLOW_COOKIE_SECURE=

# --- Proxies confiaveis (importante atras de um proxy/CDN) ---
# Numero de proxies CONFIAVEIS na frente do app. Usado para descobrir o IP real
# do cliente no rate limit do login. O X-Forwarded-For e definido pelo cliente e
# o proxy APENDA o IP que observou; este numero diz quantas entradas, a partir da
# direita, sao confiaveis. Em branco/0 = ignora o XFF e usa o IP do socket
# (correto para uso local e o mais seguro). No Railway (1 proxy na frente) defina
# 1, senao um atacante pode forjar o XFF e burlar o rate limit do login.
CONTAS_FLOW_TRUSTED_PROXIES=

# --- YouTube Data API (OAuth 2.0) ---
# Copie este arquivo para ".env" e preencha com os valores do Google Cloud.
# O ".env" NUNCA vai para o git (veja .gitignore).

# Client ID e Client Secret gerados em:
# Google Cloud Console > APIs e Serviços > Credenciais > ID do cliente OAuth (tipo "App da Web")
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# Precisa bater EXATAMENTE com um dos "URIs de redirecionamento autorizados"
# cadastrados no mesmo ID do cliente OAuth.
# Local (Fase 0): http://127.0.0.1:8787/api/youtube/callback
# Produção (depois): https://SEU-DOMINIO/api/youtube/callback
YOUTUBE_REDIRECT_URI=http://127.0.0.1:8787/api/youtube/callback
